{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.nextgenacademy.org.in" }],
      "destination": "https://nextgenacademy.org.in/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|images/|favicon\\.png|robots\\.txt|sitemap\\.xml|site\\.webmanifest|icons\\.svg).*)",
      "destination": "/index.html"
    }
  ]
}
